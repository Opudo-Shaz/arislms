# Database
DATABASE_URL=postgresql://user:password@localhost:5432/arislms
JWT_SECRET=your_jwt_secret_key_here

# Server
SERVER_PORT=6505

# CORS
# Comma-separated list of allowed origins (no spaces after commas)
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Accounting
# Rounding tolerance (in currency units) for money comparisons. Amounts are stored
# to 2 decimals, so anything at or below this half-cent value is treated as zero.
CURRENCY_EPSILON=0.005
